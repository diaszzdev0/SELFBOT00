# ── DISCORD SELFBOT ──
# Como pegar o token:
# 1. Abra Discord no navegador
# 2. Pressione F12 > Network > Ctrl+R
# 3. Procure "authorization" nos headers
DISCORD_TOKEN=COLE_SEU_TOKEN_AQUI

# Como pegar SERVER_ID:
# 1. Ative Modo Desenvolvedor (Configurações > Avançado)
# 2. Clique direito no servidor > Copiar ID
# Exemplo: 1234567890123456789
SERVER_ID=COLE_O_ID_DO_SERVIDOR_AQUI

# Como pegar CATEGORY_ID:
# 1. Clique direito na categoria > Copiar ID
# Exemplo: 9876543210987654321
CATEGORY_ID=COLE_O_ID_DA_CATEGORIA_AQUI

# ── EMAIL IMAP (GMAIL) ──
# Seu email do Gmail
# Exemplo: seuemail@gmail.com
EMAIL_USER=COLE_SEU_EMAIL_AQUI

# Senha de app (NÃO é sua senha normal!)
# Como gerar: https://myaccount.google.com/apppasswords
# Exemplo: abcdefghijklmnop (16 caracteres sem espaços)
EMAIL_PASS=COLE_A_SENHA_DE_APP_AQUI

# Servidor IMAP (deixe como está)
IMAP_SERVER=imap.gmail.com

# ── MENSAGEM E IMAGEM (OPCIONAL) ──
# Mensagem enviada quando thread é criada
THREAD_MESSAGE=Olá! Digite: pago Nome Sobrenome para validar seu pagamento de hoje.

# URL da imagem (deixe vazio se não quiser imagem)
